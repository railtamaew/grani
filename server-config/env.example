# GRANI VPN Environment Configuration Template
# Скопируйте этот файл в env-production.env и заполните реальными значениями
# НЕ коммитьте файлы с реальными секретами в Git!

# Database Configuration
DB_PASSWORD=your_secure_database_password_here
DB_HOST=postgres
DB_PORT=5432
DB_NAME=granivpn
POSTGRES_PASSWORD=your_secure_database_password_here
DATABASE_URL=postgresql://granivpn_user:your_secure_database_password_here@postgres:5432/granivpn

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://:your_secure_redis_password_here@redis:6379
# Обязательно при нескольких воркерах API (Docker уже использует Gunicorn)
CACHE_BACKEND=redis
RATE_LIMIT_STORE=redis

# GET /api/vpn/status: по умолчанию только БД (connected/server/protocol), без SSH к ноде за Xray Stats API.
# Установите 1 только для отладки live uplink/downlink (может давать долгие ответы, если на ноде нет 10085).
# VPN_STATUS_REMOTE_XRAY_STATS=0

# Метрики Prometheus: GET /metrics/prometheus (в nginx на api.granilink.com — только 127.0.0.1; см. server-config/OPS.md)
METRICS_PROMETHEUS_ENABLED=false
# JSON lines в файл логов API (см. BACKEND_LOG_JSON в backend/.env.example)
# BACKEND_LOG_JSON=false

# Security
# ВАЖНО: Сгенерируйте криптографически стойкий ключ:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_cryptographically_secure_secret_key_here_minimum_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DOMAIN=granilink.com
API_URL=https://api.granilink.com
# Доп. базовые URL для GET /api/vpn/bootstrap (через запятую, с суффиксом /api)
API_BASE_URL_FALLBACKS=https://api.granilink.com/api

# Старый SECRET_KEY для ротации (опционально, оставьте пустым если не ротируете)
# Используется для graceful migration без logout пользователей
SECRET_KEY_OLD=

# CORS Configuration
CORS_ORIGINS=https://admin.granilink.com,https://app.granilink.com

# Admin Panel Configuration
REACT_APP_API_URL=https://api.granilink.com

# SSL Configuration
SSL_EMAIL=your-email@example.com

# Payment Systems - Google Play Billing
# Локальный тест: положите ключ в secrets/google-play/play-publisher.json (репо, в .gitignore) и смонтируйте в контейнер API.
GOOGLE_PLAY_SERVICE_ACCOUNT=/path/to/service-account.json
GOOGLE_PLAY_PACKAGE_NAME=com.granivpn.mobile

# VPN Configuration
WIREGUARD_SERVER_IP=YOUR_SERVER_IP
WIREGUARD_PORT=51820

# Email SMTP Configuration (Yandex) - используется если USE_AWS_SES=false
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USERNAME=your-email@yandex.ru
SMTP_PASSWORD=your_smtp_app_password_here
SMTP_FROM_EMAIL=your-email@yandex.ru
SMTP_FROM_NAME=GRANI
SMTP_USE_SSL=true
SMTP_USE_TLS=false

# Yandex Cloud Postbox Configuration (API вместо SMTP) - используется если USE_AWS_SES=true
AWS_ACCESS_KEY_ID=your_yandex_access_key_id
AWS_SECRET_ACCESS_KEY=your_yandex_secret_access_key
AWS_REGION=ru-central1
AWS_SES_ENDPOINT=https://postbox.cloud.yandex.net
AWS_SES_FROM_EMAIL=support@granilink.com
AWS_SES_FROM_NAME=GRANI
USE_AWS_SES=false

# Environment
ENV=production
